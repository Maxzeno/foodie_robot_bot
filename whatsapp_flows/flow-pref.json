{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "USER_PROFILE": []
  },
  "screens": [
    {
      "id": "USER_PROFILE",
      "title": "Your Profile",
      "data": {
        "currency_helper": {
          "type": "string",
          "__example__": "Enter amount per meal (USD)"
        },
        "fitness_goals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "1",
              "title": "Weight Loss"
            },
            {
              "id": "2",
              "title": "Muscle Gain"
            }
          ]
        },
        "health_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "1",
              "title": "Diabetes"
            },
            {
              "id": "2",
              "title": "High Blood Pressure"
            }
          ]
        },
        "allergies_diet": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "1",
              "title": "Dairy"
            },
            {
              "id": "2",
              "title": "Gluten"
            }
          ]
        },
        "preferred_cuisines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "1",
              "title": "Mediterranean"
            },
            {
              "id": "2",
              "title": "Asian"
            }
          ]
        },
        "selected_fitness_goal": {
          "type": "string",
          "__example__": "1"
        },
        "current_meal_budget": {
          "type": "number",
          "__example__": 0
        },
        "selected_health_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1", "2"]
        },
        "selected_allergies_diet": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["1"]
        },
        "selected_preferred_cuisines": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "__example__": ["2"]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "health_form",
            "init-values": {
              "meal_budget": "${data.current_meal_budget}",
              "fitness_goal": "${data.selected_fitness_goal}",
              "health_conditions": "${data.selected_health_conditions}",
              "allergies_diet": "${data.selected_allergies_diet}",
              "preferred_cuisines": "${data.selected_preferred_cuisines}"
            },
            "children": [
              {
                "type": "TextSubheading",
                "text": "Let's create your personalized health & fitness profile"
              },
              {
                "type": "RadioButtonsGroup",
                "label": "What is your primary fitness goal?",
                "name": "fitness_goal",
                "data-source": "${data.fitness_goals}",
                "required": true
              },
              {
                "type": "CheckboxGroup",
                "label": "Do you have any of these health conditions?",
                "name": "health_conditions",
                "data-source": "${data.health_conditions}"
              },
              {
                "type": "CheckboxGroup",
                "label": "Any food allergies or dietary restrictions?",
                "name": "allergies_diet",
                "data-source": "${data.allergies_diet}"
              },
              {
                "type": "CheckboxGroup",
                "label": "Which cuisines do you enjoy?",
                "name": "preferred_cuisines",
                "data-source": "${data.preferred_cuisines}"
              },
              {
                "type": "TextInput",
                "label": "Average meal budget?",
                "name": "meal_budget",
                "input-type": "number",
                "helper-text": "${data.currency_helper}",
                "min-chars": 1
              },
              {
                "type": "Footer",
                "label": "Create My Profile",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "fitness_goal": "${form.fitness_goal}",
                    "health_conditions": "${form.health_conditions}",
                    "allergies_diet": "${form.allergies_diet}",
                    "preferred_cuisines": "${form.preferred_cuisines}",
                    "meal_budget": "${form.meal_budget}"
                  }
                }
              }
            ]
          }
        ]
      },
      "terminal": true
    }
  ]
}
