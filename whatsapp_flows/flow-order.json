{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "ORDER_FLOW": []
  },
  "screens": [
    {
      "id": "ORDER_FLOW",
      "title": "Place order",
      "data": {
        "current_address": {
          "type": "string",
          "__example__": "123 Main Street, Port Harcourt, Rivers State"
        },
        "maps_url": {
          "type": "string",
          "__example__": "https://maps.google.com/?q=4.8156,7.0498"
        },
        "meal_id": {
          "type": "number",
          "__example__": 0
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "delivery_form",
            "init-values": {
              "number_of_plates": 1
            },
            "children": [
              {
                "type": "TextInput",
                "label": "Number of plates",
                "name": "number_of_plates",
                "input-type": "number",
                "helper-text": "How many plates would you like to order?",
                "required": true,
                "min-chars": 1
              },
              {
                "type": "TextBody",
                "text": "Current delivery address:"
              },
              {
                "type": "TextCaption",
                "text": "${data.current_address}"
              },
              {
                "type": "EmbeddedLink",
                "text": "View on Google Maps",
                "on-click-action": {
                  "name": "open_url",
                  "url": "${data.maps_url}"
                }
              },
              {
                "type": "TextCaption",
                "text": "💡 If this isn't your delivery location, you can go back and update your address before continuing."
              },
              {
                "type": "TextArea",
                "label": "Special instructions",
                "name": "special_instructions",
                "helper-text": "e.g., Extra spicy, no onions, allergy notes",
                "required": false,
                "max-length": 500
              },
              {
                "type": "TextArea",
                "label": "Rider instructions",
                "name": "rider_instructions",
                "helper-text": "How should we deliver? (house number, landmarks, etc.)",
                "required": false,
                "max-length": 500
              },
              {
                "type": "Footer",
                "label": "Place order",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "number_of_plates": "${form.number_of_plates}",
                    "special_instructions": "${form.special_instructions}",
                    "rider_instructions": "${form.rider_instructions}",
                    "meal_id": "${data.meal_id}"
                  }
                }
              }
            ]
          }
        ]
      },
      "terminal": true
    }
  ]
}
